@model SWMSU.Models.StudentProfileVM

<h2>Edit Profile</h2>

<form asp-action="EditProfile" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="StudentProfileId" />
    <input type="hidden" asp-for="UserId" />

    <h4>User Info</h4>
    <div class="form-group">
        <label>Name</label>
        <input asp-for="UserName" class="form-control" />
    </div>

    <div class="form-group">
        <label>Email</label>
        <input asp-for="Email" class="form-control" />
    </div>

    <div class="form-group">
        <label>Address</label>
        <input asp-for="Address" class="form-control" />
    </div>

    <div class="form-group">
        <label>Blood Group</label>
        <input asp-for="BloodGroup" class="form-control" />
    </div>

    <hr />

    <h4>Student Profile Info</h4>
    <div class="form-group">
        <label>Student ID</label>
        <input asp-for="StudentId" class="form-control" />
    </div>

    <div class="form-group">
        <label>Semester</label>
        <input asp-for="Semester" class="form-control" />
    </div>

    <div class="form-group">
        <label>CGPA</label>
        <input asp-for="CGPA" class="form-control" />
    </div>

    <div class="form-group">
        <label>Credit</label>
        <input asp-for="Credit" class="form-control" />
    </div>

    <div class="form-group">
        <label>Department</label>
        <input asp-for="Department" class="form-control" />
    </div>

    <div class="form-group">
        <label>Profile Image</label>
        <input asp-for="ImageFile" type="file" class="form-control" />
        @if (!string.IsNullOrEmpty(Model.Imageurl))
        {
            <img src="~/Images/Student/@Model.Imageurl" width="100" class="mt-2" />
        }
    </div>

    <button type="submit" class="btn btn-success mt-3">Update Profile</button>
</form>
