@model SWMSU.Models.BookVM

@{
    ViewData["Title"] = "Book Appointment";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-primary text-white text-center rounded-top-4">
                    <h4 class="mb-0">📅 Book Appointment</h4>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Book" method="post">

                        <!-- ===== Hidden Fields ===== -->
                        <input type="hidden" id="PsychiatristId"
                               asp-for="PsychiatristId"
                               value="@ViewBag.PsychiatristId" />

                        <input type="hidden" asp-for="UserId" />
                        <input type="hidden" asp-for="PsychiatristScheduleId" />
                        <input type="hidden" asp-for="AppointmentDay" id="AppointmentDay" />

                        <!-- ===== Appointment Date ===== -->
                        <div class="form-group mb-3">
                            <label asp-for="AppointmentDate" class="form-label fw-bold">
                                Appointment Date
                            </label>
                            <input id="AppointmentDate"
                                   asp-for="AppointmentDate"
                                   type="date"
                                   class="form-control"
                                   min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="AppointmentDate" class="text-danger"></span>
                        </div>

                        <!-- ===== Appointment Time ===== -->
                        <div class="form-group mb-3">
                            <label asp-for="AppointmentTime" class="form-label fw-bold">
                                Select Time
                            </label>
                            <select asp-for="AppointmentTime"
                                    class="form-select"
                                    id="AppointmentTime">
                                <option value="">Select Time</option>
                            </select>
                            <span asp-validation-for="AppointmentTime" class="text-danger"></span>
                        </div>

                        <!-- ===== Notes ===== -->
                        <div class="form-group mb-3">
                            <label asp-for="notes" class="form-label fw-bold">Notes</label>
                            <textarea asp-for="notes"
                                      class="form-control"
                                      rows="3"
                                      placeholder="Write any notes..."></textarea>
                            <span asp-validation-for="notes" class="text-danger"></span>
                        </div>

                        <!-- ===== Buttons ===== -->
                        <div class="d-grid gap-2">
                            <button type="submit"
                                    class="btn btn-success btn-lg rounded-pill shadow-sm">
                                ✅ Confirm Booking
                            </button>

                            <a asp-action="BookFrontPage"
                               class="btn btn-outline-secondary rounded-pill">
                                ⬅ Back
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $('#AppointmentDate').on('change', function () {

            var psychiatristId = $('#PsychiatristId').val();
            var appointmentDate = $(this).val();

            var $timeSelect = $('#AppointmentTime');
            $timeSelect.empty();
            $timeSelect.append('<option value="">Select Time</option>');

            if (!appointmentDate || !psychiatristId) {
                return;
            }

            $.ajax({
                url: '@Url.Action("GetScheduleByAppointmentDate", "Request")',
                type: 'POST',
                data: {
                    PsychiatristId: psychiatristId,
                    AppointmentDate: appointmentDate
                },
                success: function (response) {

                    console.log(response);

                    if (!response || !response.times || response.times.length === 0) {
                        alert("No available schedule for this date");
                        return;
                    }

                    // Set appointment day
                    $('#AppointmentDay').val(response.dayName);

                    // Populate time slots
                    for (var i = 0; i < response.times.length; i++) {
                        var text =
                            response.times[i].startTime +
                            " - " +
                            response.times[i].endTime;

                        $timeSelect.append(
                            $('<option></option>')
                                .val(response.times[i].startTime)
                                .text(text)
                        );
                    }
                },
                error: function () {
                    alert("Failed to load appointment times");
                }
            });
        });
    </script>
}
