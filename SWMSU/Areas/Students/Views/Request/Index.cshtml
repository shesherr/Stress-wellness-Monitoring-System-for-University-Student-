@model List<SWMSU.Models.CounsellingRequest>

@{
    ViewData["Title"] = "Counselling Request Report";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    .pdf-report {
        page-break-inside: avoid;
        overflow: visible !important;
    }
</style>

<div class="container mt-4">

    <div class="text-center mb-4">
        <h3 class="fw-bold">Counselling Request Report</h3>
        <hr />
    </div>

    @foreach (var item in Model)
    {
        <!-- PDF WRAPPER -->
        <div id="report-@item.BookingSerial" class="pdf-report">
            <div class="text-center mb-4">
                <h5 class="fw-bold text-uppercase mb-1">
                    International University of Business Agriculture and Technology (IUBAT)
                </h5>
                <p class="fst-italic mb-0">
                    Counselling & Psychological Support Center
                </p>
                <hr />
            </div>


            <div class="card shadow mb-4">
                <div class="card-body">


                    <!-- ===== Appointment & Request Information Section ===== -->



                    <div class="row">

                        <!-- Left Side: Appointment Info -->
                        <div class="col-md-6">
                            <h6 class="fw-bold text-primary">Appointment Info</h6>

                            <p><strong>Booking Serial:</strong> @item.BookingSerial</p>
                            <p><strong>Date:</strong> @(item.AppointmentDate.HasValue? item.AppointmentDate.Value.ToString("dd MMM yyyy") : "Not Scheduled")</p>
                            <p><strong>Day:</strong> @item.AppointmentDay</p>
                            <p><strong>Time:</strong> @item.AppointmentTime</p>
                            <p><strong>Room:</strong> @item.Room</p>
                        </div>

                        <!-- Right Side: Request Info -->
                        <div class="col-md-6">
                            <h6 class="fw-bold text-success">Request Info</h6>

                            <p><strong>Status:</strong> @item.ApprovalStatus</p>
                            <p><strong>Request Date:</strong> @item.CreatedAt.ToString("dd MMM yyyy hh:mm tt")</p>
                            <p><strong>Message:</strong> @item.Message</p>
                        </div>

                    </div>

                    <hr />

                    <!-- ===== End Section ===== -->
                    <!-- ===== Student & Psychologist Information ===== -->



                    <div class="row">

                        <!-- Left Side: Student Information -->
                        <div class="col-md-6">
                            <h6 class="fw-bold text-success">Student Information</h6>

                            <p><strong>Name:</strong> @item.StudentName</p>
                            <p><strong>Email:</strong> @item.StudentEmail</p>
                            <p><strong>Phone:</strong> @item.StudentPhone</p>
                            <p><strong>ID:</strong> @item.StudentId</p>
                            <p><strong>Department:</strong> @item.Department</p>
                            <p><strong>Semester:</strong> @item.Semester</p>
                            <p><strong>CGPA:</strong> @item.CGPA</p>
                            <p><strong>Completed Credit:</strong> @item.Credit</p>
                        </div>

                        <!-- Right Side: Psychologist Information -->
                        <div class="col-md-6">
                            <h6 class="fw-bold text-danger">Psychologist Information</h6>

                            <p><strong>Name:</strong> @item.PsychologistName</p>
                            <p><strong>Email:</strong> @item.PsychologistEmail</p>
                            <p><strong>Phone:</strong> @item.PsychologistPhone</p>
                            <p><strong>Qualification:</strong> @item.Qualification</p>
                            <p><strong>Specialization:</strong> @item.Specialization</p>
                            <p><strong>Experience:</strong> @item.ExperienceYears Years</p>
                        </div>

                    </div>

                    <hr />
                    <!-- ===== End Section ===== -->














                </div>
            </div>
            <br>
            <br>
            <div class="text-center mt-4" style="font-size: 20px; color: #555;">
                <p class="mb-0 fw-semibold">
                    Stress & Wellness Monitoring System for University Students
                </p>
                <p class=" fst-italic mb-0">
                    Department of Computer Science & Engineering, IUBAT
                </p>
            </div>
















            <div id="downloadSection" class="text-end mb-5">
                <button class="btn btn-success"
                        onclick="downloadPdf('report-@item.BookingSerial','@item.StudentId')">
                    ⬇ Download PDF
                </button>
            </div>


        </div>
    }
</div>

<!-- PDF LIB -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

<script>
    function downloadPdf(reportId, studentId) {

        const element = document.getElementById(reportId);

        const options = {
            margin: 10,
            filename: 'Counselling_Report_' + studentId + '.pdf',
            image: { type: 'jpeg', quality: 1 },
            html2canvas: {
                scale: 3,
                useCORS: true,
                scrollY: 0
            },
            jsPDF: {
                unit: 'mm',
                format: 'a4',
                orientation: 'portrait'
            },
            pagebreak: { mode: ['css', 'legacy'] }
        };

        html2pdf().set(options).from(element).save();

         document.getElementById("downloadSection").style.display = "none";

    }
</script>

