@* Form.cshtml *@
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "DASS-21 Form";
}

<div class="container mt-3">
    <div class="card p-4">
        <header class="mb-3 d-flex justify-content-between align-items-center">
            <div class="logo h3">Check Your Mental Health</div>
            <div class="meta d-flex gap-3">
                @* <div>
                    <label>Date:</label>
                    <input type="date" name="Date" class="form-control" required />
                </div> *@
                <div>
                    <label>Date:</label>
                    <input type="date"
                           name="Date"
                           class="form-control"
                           required
                           min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                </div>

            </div>
        </header>

        <div class="instructions mb-3 p-3" style="background:#fbfdff; border:1px solid #eef2ff; border-radius:6px;">
            <p style="margin:0; font-weight:600">
                Please read each statement and circle a number 0, 1, 2 or 3 which indicates how much the statement applied to you <strong>over the past week</strong>.
                There are no right or wrong answers. Do not spend too much time on any statement.
            </p>
            <div class="scale mt-2" style="color:#6b7280;">
                <strong>The rating scale is as follows:</strong>
                <div class="d-flex flex-wrap gap-3 mt-2">
                    <div><strong>0</strong> Did not apply to me at all</div>
                    <div><strong>1</strong> Applied to me to some degree, or some of the time</div>
                    <div><strong>2</strong> Applied to me to a considerable degree or a good part of time</div>
                    <div><strong>3</strong> Applied to me very much or most of the time</div>
                </div>
            </div>
        </div>

        <form asp-area="Students" asp-controller="Student" asp-action="Form" method="post">
            <!-- Question 1 -->
            <div class="q-row mb-3">
                <label class="fw-bold">1. I found it hard to wind down?</label>
                <div class="options">
                    <label><input type="radio" name="q1" value="0" required />0</label>
                    <label><input type="radio" name="q1" value="1" />1</label>
                    <label><input type="radio" name="q1" value="2" />2</label>
                    <label><input type="radio" name="q1" value="3" />3</label>
                </div>
            </div>

            <!-- Question 2 -->
            <div class="q-row mb-3">
                <label class="fw-bold">2. I couldn't seem to experience any positive feeling at all?</label>
                <div class="options">
                    <label><input type="radio" name="q2" value="0" required />0</label>
                    <label><input type="radio" name="q2" value="1" />1</label>
                    <label><input type="radio" name="q2" value="2" />2</label>
                    <label><input type="radio" name="q2" value="3" />3</label>
                </div>
            </div>

            <!-- Question 3 -->
            <div class="q-row mb-3">
                <label class="fw-bold">3. I found it difficult to work up the initiative to do things?</label>
                <div class="options">
                    <label><input type="radio" name="q3" value="0" required />0</label>
                    <label><input type="radio" name="q3" value="1" />1</label>
                    <label><input type="radio" name="q3" value="2" />2</label>
                    <label><input type="radio" name="q3" value="3" />3</label>
                </div>
            </div>

            <!-- Question 4 -->
            <div class="q-row mb-3">
                <label class="fw-bold">4. I tended to over-react to situations?</label>
                <div class="options">
                    <label><input type="radio" name="q4" value="0" required />0</label>
                    <label><input type="radio" name="q4" value="1" />1</label>
                    <label><input type="radio" name="q4" value="2" />2</label>
                    <label><input type="radio" name="q4" value="3" />3</label>
                </div>
            </div>

            <!-- Question 5 -->
            <div class="q-row mb-3">
                <label class="fw-bold">5. I felt that I was using a lot of nervous energy?</label>
                <div class="options">
                    <label><input type="radio" name="q5" value="0" required />0</label>
                    <label><input type="radio" name="q5" value="1" />1</label>
                    <label><input type="radio" name="q5" value="2" />2</label>
                    <label><input type="radio" name="q5" value="3" />3</label>
                </div>
            </div>

            <!-- Question 6 -->
            <div class="q-row mb-3">
                <label class="fw-bold">6. I felt that I had nothing to look forward to?</label>
                <div class="options">
                    <label><input type="radio" name="q6" value="0" required />0</label>
                    <label><input type="radio" name="q6" value="1" />1</label>
                    <label><input type="radio" name="q6" value="2" />2</label>
                    <label><input type="radio" name="q6" value="3" />3</label>
                </div>
            </div>

            <!-- Question 7 -->
            <div class="q-row mb-3">
                <label class="fw-bold">7. I found myself getting agitated?</label>
                <div class="options">
                    <label><input type="radio" name="q7" value="0" required />0</label>
                    <label><input type="radio" name="q7" value="1" />1</label>
                    <label><input type="radio" name="q7" value="2" />2</label>
                    <label><input type="radio" name="q7" value="3" />3</label>
                </div>
            </div>

            <!-- Question 8 -->
            <div class="q-row mb-3">
                <label class="fw-bold">8. I found it difficult to relax?</label>
                <div class="options">
                    <label><input type="radio" name="q8" value="0" required />0</label>
                    <label><input type="radio" name="q8" value="1" />1</label>
                    <label><input type="radio" name="q8" value="2" />2</label>
                    <label><input type="radio" name="q8" value="3" />3</label>
                </div>
            </div>

            <!-- Question 9 -->
            <div class="q-row mb-3">
                <label class="fw-bold">9. I felt down-hearted and blue?</label>
                <div class="options">
                    <label><input type="radio" name="q9" value="0" required />0</label>
                    <label><input type="radio" name="q9" value="1" />1</label>
                    <label><input type="radio" name="q9" value="2" />2</label>
                    <label><input type="radio" name="q9" value="3" />3</label>
                </div>
            </div>

            <!-- Question 10 -->
            <div class="q-row mb-3">
                <label class="fw-bold">10. I was intolerant of anything that kept me from getting on with what I was doing?</label>
                <div class="options">
                    <label><input type="radio" name="q10" value="0" required />0</label>
                    <label><input type="radio" name="q10" value="1" />1</label>
                    <label><input type="radio" name="q10" value="2" />2</label>
                    <label><input type="radio" name="q10" value="3" />3</label>
                </div>
            </div>

            <!-- Question 11 -->
            <div class="q-row mb-3">
                <label class="fw-bold">11. I was unable to become enthusiastic about anything?</label>
                <div class="options">
                    <label><input type="radio" name="q11" value="0" required />0</label>
                    <label><input type="radio" name="q11" value="1" />1</label>
                    <label><input type="radio" name="q11" value="2" />2</label>
                    <label><input type="radio" name="q11" value="3" />3</label>
                </div>
            </div>

            <!-- Question 12 -->
            <div class="q-row mb-3">
                <label class="fw-bold">12. I felt I wasn't worth much as a person?</label>
                <div class="options">
                    <label><input type="radio" name="q12" value="0" required />0</label>
                    <label><input type="radio" name="q12" value="1" />1</label>
                    <label><input type="radio" name="q12" value="2" />2</label>
                    <label><input type="radio" name="q12" value="3" />3</label>
                </div>
            </div>

            <!-- Question 13 -->
            <div class="q-row mb-3">
                <label class="fw-bold">13. I felt that I was rather touchy?</label>
                <div class="options">
                    <label><input type="radio" name="q13" value="0" required />0</label>
                    <label><input type="radio" name="q13" value="1" />1</label>
                    <label><input type="radio" name="q13" value="2" />2</label>
                    <label><input type="radio" name="q13" value="3" />3</label>
                </div>
            </div>

            <!-- Question 14 -->
            <div class="q-row mb-3">
                <label class="fw-bold">14. I felt that life was meaningless?</label>
                <div class="options">
                    <label><input type="radio" name="q14" value="0" required />0</label>
                    <label><input type="radio" name="q14" value="1" />1</label>
                    <label><input type="radio" name="q14" value="2" />2</label>
                    <label><input type="radio" name="q14" value="3" />3</label>
                </div>
            </div>

            <div class="actions mt-3 d-flex gap-2 justify-content-end">
                <button type="button" class="btn btn-secondary" onclick="document.querySelector('form').reset();">Reset</button>
                <button type="submit" class="btn btn-primary">Submit</button>
            </div>
        </form>

        <div class="mt-3 text-muted small">
            <strong>Note:</strong> This page is a frontend-only mockup of the DASS-21 questionnaire. No results are stored or processed on a server.
        </div>
    </div>
</div>

<style>
    .q-row {
        border-bottom: 1px solid #eef2f6;
        padding-bottom: 5px;
    }

    .options label {
        margin-right: 10px;
        cursor: pointer;
    }

    .options input[type=radio] {
        margin-right: 3px;
    }
</style>










































