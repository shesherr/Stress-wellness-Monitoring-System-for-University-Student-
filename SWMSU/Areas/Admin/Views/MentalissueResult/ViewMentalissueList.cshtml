@model IEnumerable<SWMSU.Models.MentalissueListVM>

<!-- ===== EMBEDDED STYLES ===== -->
<style>
    #mentalTable_wrapper {
        background: #ffffff;
        padding: 16px;
        border-radius: 12px;
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
    }

    #mentalTable {
        font-size: 14px;
        white-space: nowrap;
    }

        #mentalTable thead th {
            background: linear-gradient(135deg, #0d6efd, #0b5ed7);
            color: #fff;
            text-align: center;
            font-weight: 600;
            vertical-align: middle;
            border: none;
            position: sticky;
            top: 0;
            z-index: 2;
        }

        #mentalTable tbody td {
            text-align: center;
            vertical-align: middle;
            padding: 8px 12px;
        }

            /* Left aligned important text columns */
            #mentalTable tbody td:nth-child(1),
            #mentalTable tbody td:nth-child(2),
            #mentalTable tbody td:nth-child(5) {
                text-align: left;
                font-weight: 500;
            }

        /* Zebra rows */
        #mentalTable tbody tr:nth-child(even) {
            background-color: #f8f9fa;
        }

        /* Hover highlight */
        #mentalTable tbody tr:hover {
            background-color: #eef4ff;
            transition: 0.2s ease-in-out;
        }

        /* Depression column */
        #mentalTable tbody td:nth-last-child(2) {
            font-weight: 700;
            color: #dc3545;
        }

        /* Stress column */
        #mentalTable tbody td:last-child {
            font-weight: 700;
            color: #fd7e14;
        }

    /* Datatable inputs */
    .dataTables_filter input,
    .dataTables_length select {
        border-radius: 6px;
        border: 1px solid #ced4da;
        padding: 5px 10px;
    }

    /* Pagination */
    .page-item.active .page-link {
        background-color: #0d6efd;
        border-color: #0d6efd;
    }

    /* Smooth scrollbar */
    div.dataTables_scrollBody {
        scrollbar-width: thin;
    }
</style>

