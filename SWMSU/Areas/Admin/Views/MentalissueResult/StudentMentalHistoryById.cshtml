@model List<SWMSU.Models.StudentMentalHistoryVM>

@{
    ViewData["Title"] = "Student Mental Health History";
}

<!-- Bootstrap -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<!-- DataTables CSS -->
<link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet" />

<div class="container mt-4">

    <div class="text-center mb-4">
        <h3 class="fw-bold text-primary">🧠 Student Mental Health Timeline</h3>
        <p class="text-muted">Depression, Stress & Psychologist history</p>
        <hr />
    </div>

    @if (Model != null && Model.Any())
    {
        <!-- Student Info -->
        <div class="card shadow mb-3">
            <div class="card-body">
                <h5 class="fw-bold">@Model[0].StudentName</h5>
                <span class="text-muted">
                    Semester: @Model[0].Semester | Credit: @Model[0].Credit
                </span>
            </div>
        </div>

        <!-- History Table -->
        <div class="card shadow">
            <div class="card-body table-responsive">

                <table id="patienttable" class="table table-bordered table-hover align-middle">
                    <thead class="table-dark text-center">
                        <tr>
                            <th>Form Date</th>
                            <th>Depression</th>
                            <th>Stress</th>
                            <th>Psychologist</th>
                            <th>Appointment</th>
                            <th>Status</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Dass21FormDate.ToString("dd MMM yyyy")</td>

                                <td class="text-center">
                                    <span class="badge bg-danger">@item.Depression</span>
                                </td>

                                <td class="text-center">
                                    <span class="badge bg-warning text-dark">@item.Stress</span>
                                </td>

                                <td>
                                    <div class="d-flex align-items-center">
                                        
                                        <b>@item.PsychologistName</b>
                                    </div>
                                </td>

                                <td>
                                    📅 @item.AppointmentDate.ToString("dd MMM yyyy") <br />
                                    🕒 @item.AppointmentTime <br />
                                    <small>@item.AppointmentDay</small>
                                </td>

                                <td class="text-center">
                                    @if (item.CompletedAt != null)
                                    {
                                        <span class="badge bg-success">Completed</span>
                                    }
                                    else if (item.ApprovedAt != null)
                                    {
                                        <span class="badge bg-primary">Approved</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

            </div>
            <div class="text-end mb-3">
                <button class="btn btn-danger" onclick="downloadPDF()">
                    📄 Download PDF
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-danger text-center">
            No mental health history found for this student.
        </div>
    }

</div>

