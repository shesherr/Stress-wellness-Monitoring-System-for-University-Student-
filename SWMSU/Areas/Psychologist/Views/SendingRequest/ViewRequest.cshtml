                                    <td class="text-center">
                                        @if (item.ApprovalStatus == "Pending")
                                        {
                                            <form asp-area="Psychologist"
                                                  asp-controller="SendingRequest"
                                                  asp-action="Approve"
                                                  method="post"
                                                  class="d-inline">
                                                <input type="hidden" name="RequestId" value="@item.RequestId" />
                                                <button class="btn btn-sm btn-success">
                                                    Approve
                                                </button>
                                            </form>
                                        }
                                        else if (item.ApprovalStatus == "Approved")
                                        {
                                            <span class="badge bg-success">Approved</span>
                                        }
                                        else if (item.ApprovalStatus == "Completed")
                                        {
                                            <span class="badge bg-secondary">Completed</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">@item.ApprovalStatus</span>
                                        }
                                </td>

                                <td class="text-center">
                                    @item.CreatedAt.ToString("dd MMM yyyy")
                                </td>

                                <td class="text-center fw-bold">
                                    @item.BookingSerial
                                </td>

                                <td class="text-center">
                                    @(item.AppointmentDate.HasValue
                                                                    ? item.AppointmentDate.Value.ToString("dd MMM yyyy")
                                                                    : "Not Scheduled")
                            </td>

                                    <td class="text-center">@item.AppointmentDay</td>

                                    <td class="text-center">@item.AppointmentTime</td>

                                    <!-- ACTION -->
                                    <td class="text-center">
                                @if (item.ApprovalStatus == "Approved")
                                        {
                                            <button class="btn btn-sm btn-primary"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#messageModal-@item.BookingId">
                                                Send Link
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info text-center m-3">
                    No counselling requests found.
                </div>
            }
        </div>
    </div>
</div>

<!-- ================= MODALS ================= -->
@foreach (var item in Model)
{
    <div class="modal fade" id="messageModal-@item.BookingId" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        Send Meet Link to @item.StudentName
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <form asp-area="Psychologist"
                      asp-controller="SendingRequest"
                      asp-action="SendMessage"
                      method="post">

                    <div class="modal-body">
                        <input type="hidden" name="BookingId" value="@item.BookingId" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Google Meet Link</label>
                            <input type="url"
                                   class="form-control"
                                   name="Message"
                                   placeholder="https://meet.google.com/xxx-yyyy-zzz"
                                   required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Appointment Time</label>
                            <input type="text"
                                   class="form-control"
                                   value="@item.AppointmentTime"
                                   readonly />
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="submit" class="btn btn-success">
                            Send
                        </button>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                            Cancel
                        </button>
                    </div>
                </form>

            </div>
        </div>
    </div>
} *@
