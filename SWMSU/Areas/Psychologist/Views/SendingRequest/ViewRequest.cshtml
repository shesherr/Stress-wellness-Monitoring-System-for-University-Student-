                            <tr>
                                <th>Student</th>
                                <th>Contact</th>
                                <th>Department</th>
                                <th>Message</th>
                                <th>Status</th>
                                <th>Request Date</th>
                                <th>Booking #</th>
                                <th>Appointment</th>
                                <th>Day</th>
                                <th>Time</th>
                                <th>Action</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>@item.StudentName</strong><br />
                                        <small class="text-muted">@item.StudentEmail</small>
                                    </td>

                                    <td>@item.StudentPhone</td>

                                    <td class="text-center">@item.Department</td>

                                    <td>@item.Message</td>

