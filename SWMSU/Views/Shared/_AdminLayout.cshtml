@* ~/Views/Shared/_AdminLayout.cshtml *@



<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Admin | Soft Blue Navbar</title>

    <!-- Google Font: Source Sans Pro -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&display=fallback">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="~/Admin/plugins/fontawesome-free/css/all.min.css">
    <!-- Theme style -->
    <link rel="stylesheet" href="~/Admin/dist/css/adminlte.min.css">
    <!-- DataTables CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap4.min.css">

    <!-- Custom CSS for navbar -->
    <style>
        .main-header.navbar {
         
            background: linear-gradient(90deg, #A8DADC, #457B9D);
            /* Soft blue gradient */
        }

        .navbar-nav .nav-link {
            color: #fff !important;
            transition: all 0.3s ease;
        }

            .navbar-nav .nav-link:hover {
                background-color: rgba(255, 255, 255, 0.2);
                border-radius: 5px;
            }

        /* Right-align login partial */
        .navbar-right {
            margin-left: auto;
        }
    </style>
</head>
<body class="hold-transition sidebar-mini">
    <div class="wrapper">
        <!-- Navbar -->
        <nav class="main-header navbar navbar-expand navbar-light">
            <!-- Left navbar links -->
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
                </li>
              
            </ul>

            <!-- Right navbar links -->
            <ul class="navbar-nav navbar-right">
                <li class="nav-item">
                    <partial name="_LoginPartial.cshtml" />
                </li>
            </ul>
        </nav>

        <!-- Sidebar -->
        @if (Context.Session.GetString("UsertypeId") == "1")
        {
            <partial name="~/Views/Shared/_SideBar.cshtml" />
        }
        @if (Context.Session.GetString("UsertypeId") == "2")
        {
            <partial name="~/Views/Shared/_PsychologistSidebar.cshtml" />
        }
        @if (Context.Session.GetString("UsertypeId") == "3")
  {
        <partial name="~/Views/Shared/_AdminSideBar.cshtml" />
        }
        <!-- Content Wrapper -->
        <div class="content-wrapper">
            <main role="main" class="pb-3 pl-3">
                @RenderBody()
            </main>
        </div>

        <style>
            footer {
                background: #f1f7fb;
                padding: 18px 0;
                font-weight: 600; /* Bold text */
                color: #0f4c75; /* University theme color */
                font-size: 15px;
            }

                footer a {
                    color: #3fc1c9;
                    font-weight: 700;
                    text-decoration: none;
                }

                    footer a:hover {
                        text-decoration: underline;
                    }
        </style>

        <footer class="border-top footer text-center">
            <div class="container">
                <strong>
                    Arafat Hossain Shishir ; 2025 - Stress & Wellness Monitoring System for University Students -
                    <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                </strong>
            </div>
        </footer>

        <!-- Control Sidebar -->
        <aside class="control-sidebar control-sidebar-dark">
            <!-- Control sidebar content goes here -->
        </aside>
    </div>

    <!-- Scripts -->
    <script src="~/Admin/plugins/jquery/jquery.min.js"></script>
    <script src="~/Admin/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/Admin/dist/js/adminlte.min.js"></script>
    <script src="~/Admin/dist/js/demo.js"></script>

    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap4.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>























