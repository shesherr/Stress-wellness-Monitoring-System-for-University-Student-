@* Layout *@


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SWMSU</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        /* Professional color palette (calm, wellness-inspired) */
        .navbar-custom {
            background-color: #4C7F9E; /* calm blue */
        }

            .navbar-custom .navbar-brand,
            .navbar-custom .nav-link {
                color: #ffffff !important;
                font-weight: 500;
            }

                .navbar-custom .nav-link:hover {
                    color: #E3F2FD !important;
                }

        footer {
            background: #f5f5f5;
            padding: 10px 0;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-custom navbar-toggleable-sm border-bottom shadow-sm mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    Stress & Wellness Monitoring System for University Students
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                       
                     
                      


                    </ul>

                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <style>
        footer {
            background: #f1f7fb;
            padding: 18px 0;
            font-weight: 600; /* Bold text */
            color: #0f4c75; /* University theme color */
            font-size: 15px;
        }

            footer a {
                color: #3fc1c9;
                font-weight: 700;
                text-decoration: none;
            }

                footer a:hover {
                    text-decoration: underline;
                }
    </style>

    <footer class="border-top footer text-center">
        <div class="container">
            <strong>
                Arafat Hossain Shishir ; 2025 - Stress & Wellness Monitoring System for University Students -
                <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </strong>
        </div>
    </footer>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>